# Python cache directories (do not commit)
__pycache__/
*.pyc
*.py[cod]
*.pyo
*.nbc
*.nbi
results_chunk_*.csv
.needs_aggregation
*.out

# Data and results (large / generated)
results/**
!results/
!results/*/
!results/**/
!results/**/global_results_summary.csv
!results/dl_global_results_summary.csv

# Build artifacts
*.egg-info/
dist/
build/

# Generated package — src/ is built from notebooks/ by notebooks/_build_package.py
# (convention-driven; local stand-in for `hpc-agent export-package`). Not
# committed; rebuilt on demand by conftest.py / `make export` / CI.
src/
.hpc/.build-cache.json

# Virtual environments
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# mypy / type checking
.mypy_cache/

# pytest
.pytest_cache/

# ruff
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Logs
logs/
worker_log.txt

# claude-hpc per-experiment glue: tasks.py + cli.py are tracked
# (regenerated only on intentional /submit-hpc Step 6 reruns), runs/
# is per-submission ephemera and ignored. The legacy `python -m hpc.collect`
# manifest mode is gone — artifacts under .hpc/ are now FLAGS dict +
# resolve()/total() + sidecar journal.
.hpc/runs/

# Claude Code session artifacts
.claude/worktrees/

# Pytest temp dirs
pytest-of-*/

# Generated HPC dispatch artifacts (per-run)
_hpc_dispatch*.json
_hpc_dispatch.py

# Optuna study state (binary / transient)
optuna.db
optuna_journal.log

# Generated trial params (reproducible from Optuna)
params/
params_carc/
